# Supabase. If either is unset, orders use an in-process in-memory store
# (fine for local dev/e2e; NOT viable in serverless production).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe. If STRIPE_SECRET_KEY is unset, checkout falls back to today's direct
# guide generation (no payment) so dev + e2e pass with no keys. Set the secret
# key to take real payments via hosted Checkout. STRIPE_WEBHOOK_SECRET comes
# from `stripe listen --forward-to localhost:3000/api/stripe/webhook`.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Email (Resend). If RESEND_API_KEY or EMAIL_FROM is unset, email sends are a
# logged no-op (the guide is still delivered via the success redirect).
RESEND_API_KEY=
EMAIL_FROM=

# Absolute base URL for Stripe redirects + email links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
